# ==============================================================================
# WOL Backend Production-Ready Dockerfile
# ==============================================================================
# 가볍고 보안이 뛰어난 Alpine 기반의 최신 LTS(20) 버전을 사용합니다.
FROM node:20-alpine

# 컨테이너 내 작업 디렉토리 설정
WORKDIR /app

# ------------------------------------------------------------------------------
# [최적화 1] 캐시 활용 및 의존성 설치
# 패키지 명세서(package.json)와 잠금 파일(package-lock.json)을 모두 복사합니다.
COPY package*.json ./

# npm install 대신 npm ci를 사용하여 패키지 버전 충돌을 방지하고, 
# 프로덕션 환경에 불필요한 devDependencies를 제외(--omit=dev)하여 이미지 용량을 줄입니다.
RUN npm ci --omit=dev
# ------------------------------------------------------------------------------

# 서버 구동에 필요한 실제 소스 코드를 복사합니다.
COPY server.js ./

# ------------------------------------------------------------------------------
# [최적화 2] 권한 축소 (Privilege Drop)
# 컨테이너 런타임 보안 강화를 위해 기본 root 권한을 버리고 
# node 이미지에 내장된 제한된 권한의 사용자(node)로 런타임 환경을 전환합니다.
USER node
# ------------------------------------------------------------------------------

# 컨테이너가 3000 포트에서 통신함을 문서화(명시)합니다.
EXPOSE 3000

# ------------------------------------------------------------------------------
# [최적화 3] 프로세스 PID 1 안정화
# npm start 래퍼(Wrapper)를 사용하지 않고 node 바이너리를 직접 호출하여 
# 컨테이너 라이프사이클(SIGTERM 신호 등)을 정상적으로 핸들링합니다.
CMD ["node", "server.js"]